# Supabase Configuration
# Get these values from your Supabase project settings
# Visit: https://app.supabase.com -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: Application URL (for OAuth redirects)
# This should match your deployed URL or localhost during development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: Analytics (if using)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Server-side secrets (not exposed to browser)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: Third-party API keys
# OPENAI_API_KEY=sk-...
# GOOGLE_API_KEY=...
# GITHUB_API_KEY=...
