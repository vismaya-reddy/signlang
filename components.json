{
  "$schema": "https://ui.shadcn.com/schema.json",
  "style": "new-york",
  "rsc": true,
  "tsx": true,
  "tailwind": {
    "config": "tailwind.config.ts",
    "css": "src/app/globals.css",
    "baseColor": "zinc",
    "cssVariables": true,
    "prefix": ""
  },
  "iconLibrary": "lucide",
  "aliases": {
    "components": "@/components",
    "utils": "@/lib/utils",
    "ui": "@/components/ui",
    "lib": "@/lib",
    "hooks": "@/hooks"
  },
  "registries": {
    "@magicui": "https://magicui.design/r/{name}.json",
    "@supabase": "https://supabase.com/ui/r/{name}.json",
    "@clerk": "https://clerk.com/r/{name}.json",
    "@billingsdk": "https://billingsdk.com/r/{name}.json",
    "@assistant-ui": "https://r.assistant-ui.com/{name}",
    "@elements": "https://tryelements.dev/r/{name}.json"
  }
}
